PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/shopdb

# Optional: Place your live Stripe Secret Key here to enable real credit card checkouts.
STRIPE_SECRET_KEY=sk_test_placeholder

# Note: The User Model dynamically generates a fresh encryption key per boot if ENCRYPTION_KEY is omitted. 
# Explicitly set it across server restarts to verify persistent user hashes!
ENCRYPTION_KEY=my_secure_32_byte_string_for_aes_encryption
